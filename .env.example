NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_FALLBACK_MODEL=
NVIDIA_TIMEOUT_SECONDS=45
NVIDIA_TEXT_TIMEOUT_SECONDS=60
NVIDIA_MAX_TOKENS=700
NVIDIA_TEXT_MAX_TOKENS=1800
NIM_PAGE_SLEEP_SECONDS=0
NIM_RETRY_ATTEMPTS=3
NIM_RETRY_BACKOFF_SECONDS=5

VAIDY_AGENT_DATABASE_PATH=storage/health_agent.db
VAIDY_AGENT_REPORTS_DIR=storage/reports
VAIDY_AGENT_INPUT_DIR=input
VAIDY_AGENT_OUTPUT_DIR=output
VAIDY_AGENT_SUPPORTED_EXTENSIONS=.pdf | .json | .txt | .md | .png | .jpg | .jpeg | .webp | .heic | .bmp | .tif | .tiff
VAIDY_AGENT_IMAGE_EXTENSIONS=.png | .jpg | .jpeg | .webp | .heic | .bmp | .tif | .tiff
VAIDY_AGENT_FRESH_UPLOAD_WINDOW_SECONDS=900
VAIDY_AGENT_FRESH_UPLOAD_IMPORTANCE=0.95
VAIDY_EMBEDDINGS_LOCAL_PRIMARY=true
VAIDY_ONNX_MODEL_REPO=Xenova/all-MiniLM-L6-v2
VAIDY_ONNX_MODEL_FILE=onnx/model.onnx
VAIDY_ONNX_TOKENIZER_FILE=tokenizer.json
VAIDY_ONNX_CACHE_DIR=storage/onnx_models
VAIDY_EMBEDDING_DIM=384
VAIDY_EMBEDDING_MAX_TOKENS=256
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
VAIDY_EMBEDDING_TIMEOUT_SECONDS=12
VAIDY_AGENT_SEARCH_LIMIT=5
VAIDY_CHAT_MODEL=meta/llama-4-maverick-17b-128e-instruct
VAIDY_CHAT_FAST_MODEL=meta/llama-3.1-8b-instruct
VAIDY_CHAT_REPORT_MODEL=meta/llama-3.1-8b-instruct
VAIDY_CHAT_FALLBACK_MODEL=nvidia/nemotron-mini-4b-instruct
VAIDY_CHAT_TIMEOUT_SECONDS=60
VAIDY_CHAT_MAX_TOKENS=700
VAIDY_CHAT_TEMPERATURE=0.3
VAIDY_CHAT_STREAMING=true
VAIDY_CHAT_FAST_LANE_FOR_CASUAL=true
VAIDY_CHAT_FAST_LANE_FOR_REPORTS=true
VAIDY_CHAT_WARMUP_ON_START=true
VAIDY_CHAT_HISTORY_MESSAGES=8
VAIDY_CHAT_EVIDENCE_LIMIT=5
VAIDY_CHAT_REPORT_CONTEXT_MIN_CHARS=4
VAIDY_CHAT_REPORT_CONTEXT_MARGIN=0.05

VAIDY_SUPABASE_ENABLED=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VAIDY_SUPABASE_TIMEOUT_SECONDS=8
VAIDY_SUPABASE_SYNC_ASYNC=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
VAIDY_APP_URL=http://localhost:3000

VAIDY_MEMORY_ENABLED=true
VAIDY_MEMORY_SESSION_HISTORY_MESSAGES=12
VAIDY_MEMORY_RECALL_LIMIT=6
VAIDY_MEMORY_CONTEXT_CHARS=2200
VAIDY_MEMORY_AUTO_STORE_TURNS=true
VAIDY_MEMORY_MIN_TEXT_CHARS=3
VAIDY_MEMORY_IMPORTANCE_DEFAULT=0.7
VAIDY_MEMORY_RANK_SEMANTIC_WEIGHT=0.62
VAIDY_MEMORY_RANK_IMPORTANCE_WEIGHT=0.12
VAIDY_MEMORY_RANK_OVERLAP_WEIGHT=0.18
VAIDY_MEMORY_RANK_SESSION_WEIGHT=0.08

VAIDY_API_HOST=127.0.0.1
VAIDY_API_PORT=8000
VAIDY_API_CORS_ORIGINS=http://localhost:3000 | http://127.0.0.1:3000 | http://localhost:3001 | http://127.0.0.1:3001
VAIDY_API_STREAM_KEEPALIVE_SECONDS=10
VAIDY_API_WARMUP_ON_START=true
